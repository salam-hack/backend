generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  passwordHash    String        @map("password_hash")
  name            String?
  defaultCurrency String        @default("EGP") @map("default_currency")
  locale          String        @default("en")
  timezone        String        @default("UTC")
  status          UserStatus    @default(active)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  conversations   Conversation[]
  goals           Goal[]
  messages        Message[]
  rawNotes        RawNote[]
  transactions    Transaction[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model Conversation {
  id            String             @id @default(uuid())
  userId        String             @map("user_id")
  title         String             @default("New Chat")
  status        ConversationStatus @default(active)
  lastMessageAt DateTime?          @map("last_message_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  summary       String?            @map("summary")
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      Message[]
  rawNotes      RawNote[]

  @@index([userId])
  @@index([userId, status])
  @@map("conversations")
}

model RawNote {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  conversationId String?       @map("conversation_id")
  content        String
  parsedResult   Json?         @map("parsed_result")
  status         RawNoteStatus @default(pending)
  confidence     Float?
  errorMessage   String?       @map("error_message")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  @@index([userId])
  @@index([userId, status])
  @@index([conversationId])
  @@map("raw_notes")
}

model Transaction {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  rawNoteId       String?           @map("raw_note_id")
  amount          Decimal           @db.Decimal(18, 2)
  currency        String
  category        String
  item            String?
  quantity        Decimal?          @db.Decimal(18, 3)
  type            TransactionType
  source          TransactionSource @default(manual)
  rawText         String?           @map("raw_text")
  confidence      Float?
  notes           String?
  transactionDate DateTime          @default(now()) @map("transaction_date")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  rawNote         RawNote?          @relation(fields: [rawNoteId], references: [id])
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, transactionDate(sort: Desc)])
  @@index([userId, type])
  @@index([userId, category])
  @@index([rawNoteId])
  @@map("transactions")
}

model Message {
  id             String        @id @default(uuid())
  conversationId String        @map("conversation_id")
  userId         String        @map("user_id")
  role           MessageRole
  content        String
  status         MessageStatus @default(completed)
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at")
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([userId])
  @@map("messages")
}

model Goal {
  id                   String     @id @default(uuid())
  userId               String     @map("user_id")
  title                String
  description          String?
  targetAmount         Decimal    @map("target_amount") @db.Decimal(18, 2)
  currentAmount        Decimal    @default(0) @map("current_amount") @db.Decimal(18, 2)
  status               GoalStatus @default(active)
  userExpectedDate     DateTime?  @map("user_expected_date")
  systemCalculatedDate DateTime?  @map("system_calculated_date")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@map("goals")
}

enum UserStatus {
  active
}

enum TransactionType {
  expense
  income
}

enum TransactionSource {
  manual
  ai_parsed
}

enum RawNoteStatus {
  pending
  parsed
  failed
}

enum ConversationStatus {
  active
}

enum MessageRole {
  user
  assistant
  system
}

enum MessageStatus {
  sent
  processing
  completed
  failed
}

enum GoalStatus {
  active
  completed
  canceled
}
